# Copy this to .env.local and fill in real values. Never commit .env.local.

# Server-side Vercel function keys. Never use a VITE_ prefix.
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: force the deterministic template narrator client-side,
# skipping Groq/Gemini entirely. Useful for demo rehearsal without
# burning API quota.
# VITE_FORCE_TEMPLATE=false

# Run `vercel dev` locally to serve both Vite and /api functions.
