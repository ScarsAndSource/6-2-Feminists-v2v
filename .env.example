# Copy this to .env.local and fill in real values. Never commit .env.local.

# Supabase project settings (Project Settings -> API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Groq API key for client-side AI predictions, narrative, and advocacy coach
VITE_GROQ_API_KEY=your_groq_api_key_here

# Optional: force the deterministic template narrator client-side,
# skipping Groq/Gemini entirely. Useful for demo rehearsal without
# burning API quota.
# VITE_FORCE_TEMPLATE=false

# --- The following are NOT read from this file. They're set as
# Supabase secrets (`supabase secrets set KEY=value`), never as
# VITE_-prefixed client env vars, because VITE_ vars get inlined into
# the public bundle and would leak. Listed here only so the team knows
# what needs to exist somewhere:
#
#   GROQ_API_KEY            (Edge Function secret -- supabase/functions/generate-narrative)
#   GEMINI_API_KEY          (Edge Function secret -- supabase/functions/generate-narrative)
#   DEMO_USER_ID            (Edge Function secret -- supabase/functions/get-demo-entries)
#   FORCE_LLM_FAILURE       (Edge Function secret, test-only -- "groq" | "gemini" | "both")
#
# The seed script (scripts/seed-demo.mjs) additionally needs these as
# real shell env vars when you run it locally -- also never committed:
#
#   SUPABASE_URL
#   SUPABASE_SERVICE_ROLE_KEY
